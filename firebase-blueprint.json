{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "conversations": {
      "title": "Conversation",
      "description": "A chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array", "items": { "type": "object" } },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "userId", "messages", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile data"
    },
    "/users/{userId}/conversations/{convId}": {
      "schema": "conversations",
      "description": "User's chat conversations"
    }
  }
}
